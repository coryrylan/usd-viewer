{
  "name": "usd-viewer",
  "version": "0.0.0",
  "main": "./index.js",
  "module": "./index.js",
  "typings": "./index.d.ts",
  "type": "module",
  "customElements": "dist/lib/custom-elements.json",
  "homepage": "https://github.com/coryrylan/usd-viewer",
  "keywords": [
    "web components",
    "usd",
    "3d model"
  ],
  "license": "MIT",
  "description": "experimental usd-viewer web component",
  "scripts": {
    "dev": "vite",
    "build": "pnpm run build:app && pnpm run build:lib",
    "build:lib": "vite build --config vite.config.lib.ts && pnpm run analyze",
    "build:app": "vite build",
    "analyze": "cem analyze --litelement --globs \"src/element.ts\" --outdir dist/lib",
    "preview": "vite preview",
    "deploy": "firebase deploy --only hosting:usd-viewer",
    "clean": "git clean -dfX",
    "build:wasm": "./scripts/build-wasm.sh docker",
    "build:wasm:local": "./scripts/build-wasm.sh local",
    "build:wasm:clean": "./scripts/build-wasm.sh clean"
  },
  "files": [
    "*"
  ],
  "sideEffects": [
    "./include.js",
    "./src/include.ts"
  ],
  "exports": {
    "./custom-elements.json": "./custom-elements.json",
    ".": "./index.js",
    "./include/*": "./include/*",
    "./*": "./*/index.js"
  },
  "author": {
    "name": ""
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/coryrylan/usd-viewer"
  },
  "dependencies": {
    "lit": "^2.6.1",
    "three": "^0.149.0"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "0.11.0",
    "@nvidia-elements/core": "^2.0.0",
    "@nvidia-elements/styles": "^2.0.0",
    "@nvidia-elements/themes": "^2.0.0",
    "@types/three": "^0.149.0",
    "typescript": "^5.6.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vite-plugin-static-copy": "^4.1.1"
  }
}
